/* ============================================
   ZEDE ETHIOPIAN INSTANT FOODS
   Main Stylesheet
   ============================================ */

/* ---------- CSS Variables / Design Tokens ---------- */
:root {
  --color-terracotta: #C67B4B;
  --color-terracotta-hover: #b5683a;
  --color-deep-green: #2D5A27;
  --color-spice-red: #B33A2A;
  --color-cream: #FDF6E3;
  --color-dark-brown: #3E2C1F;
  --color-soft-white: #FFFBF2;
  --color-border-light: #E7D7C0;
  --color-light-bg: #faf3e8;
  --color-footer-bg: #2e2a24;
  --color-footer-text: #e7d7c0;
  --color-footer-link: #dbbc8c;
  
  --font-heading: 'Playfair Display', serif;
  --font-body: 'Lato', sans-serif;
  
  --shadow-card: 0 12px 28px rgba(0, 0, 0, 0.04);
  --shadow-card-hover: 0 20px 35px rgba(139, 94, 60, 0.12);
  --border-radius: 24px;
  --border-radius-btn: 40px;
  
  --transition: 0.25s ease;
}

/* ---------- Reset & Base ---------- */
*,
*::before,
*::after {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  font-family: var(--font-body);
  background-color: var(--color-cream);
  color: var(--color-dark-brown);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

img {
  max-width: 100%;
  height: auto;
  display: block;
}

a {
  text-decoration: none;
  color: inherit;
}

ul {
  list-style: none;
}

/* ---------- Typography ---------- */
h1, h2, h3, h4, .serif {
  font-family: var(--font-heading);
  font-weight: 600;
}

/* ---------- Utility Classes ---------- */
.container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 24px;
}

.text-center {
  text-align: center;
}

.mt-20 {
  margin-top: 20px;
}

.mt-40 {
  margin-top: 40px;
}

.p-20 {
  padding: 20px;
}

.bg-light {
  background: var(--color-soft-white);
  border-radius: var(--border-radius);
}

.section {
  padding: 70px 0;
}

.section--light {
  background: var(--color-light-bg);
}

.section__title {
  text-align: center;
  font-size: 2.5rem;
  color: var(--color-deep-green);
  margin-bottom: 16px;
}

.section__title--left {
  text-align: left;
}

.section__subtitle {
  text-align: center;
  color: #5f4a34;
  max-width: 650px;
  margin: 0 auto 45px;
  font-size: 1.15rem;
}

/* ---------- Buttons ---------- */
.btn {
  display: inline-block;
  padding: 12px 28px;
  border-radius: var(--border-radius-btn);
  font-weight: 600;
  letter-spacing: 0.5px;
  transition: background var(--transition), transform 0.2s, color var(--transition);
  cursor: pointer;
  font-size: 1rem;
  border: none;
  font-family: var(--font-body);
}

.btn--primary {
  background: var(--color-terracotta);
  color: #fff;
}

.btn--primary:hover {
  background: var(--color-terracotta-hover);
  transform: translateY(-2px);
  color: #fff;
}

.btn--outline {
  background: transparent;
  border: 2px solid var(--color-terracotta);
  color: var(--color-terracotta);
}

.btn--outline:hover {
  background: var(--color-terracotta);
  color: #fff;
  transform: translateY(-2px);
}

.btn--text {
  background: transparent;
  color: var(--color-terracotta);
  padding: 8px 0;
  font-weight: 600;
}

.btn--text:hover {
  color: var(--color-terracotta-hover);
}

.btn--lg {
  padding: 16px 36px;
  font-size: 1.1rem;
}

.btn--full {
  width: 100%;
  text-align: center;
  justify-content: center;
}

/* ---------- Header / Navigation ---------- */
.header {
  background: var(--color-soft-white);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1px solid var(--color-border-light);
}

.nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 0;
  flex-wrap: wrap;
}

.nav__logo {
  font-family: var(--font-heading);
  font-size: 1.8rem;
  font-weight: 700;
  color: var(--color-deep-green);
  letter-spacing: 0.5px;
}

.nav__logo--highlight {
  color: var(--color-terracotta);
}

.nav__menu {
  display: flex;
  gap: 32px;
  align-items: center;
}

.nav__link {
  font-weight: 500;
  font-size: 1.05rem;
  color: var(--color-dark-brown);
  position: relative;
  transition: color var(--transition);
}

.nav__link:hover,
.nav__link--active {
  color: var(--color-terracotta);
}

.nav__link::after {
  content: '';
  position: absolute;
  width: 0;
  height: 2px;
  bottom: -4px;
  left: 0;
  background: var(--color-terracotta);
  transition: width 0.3s;
}

.nav__link:hover::after,
.nav__link--active::after {
  width: 100%;
}

.nav__toggle {
  display: none;
  font-size: 1.5rem;
  cursor: pointer;
  color: var(--color-dark-brown);
}

/* ---------- Hero Section ---------- */
.hero {
  background: linear-gradient(103deg, rgba(253, 246, 227, 0.92) 0%, rgba(253, 246, 227, 0.7) 70%),
              url('../images/hero-bg.jpg') center/cover no-repeat;
  padding: 90px 0;
  border-bottom: 2px solid var(--color-border-light);
}

.hero__content {
  max-width: 650px;
}

.hero__title {
  font-size: 3.5rem;
  font-weight: 700;
  color: var(--color-deep-green);
  line-height: 1.2;
  margin-bottom: 20px;
}

.hero__description {
  font-size: 1.3rem;
  color: #4a3a2a;
  margin-bottom: 32px;
}

.hero__buttons {
  display: flex;
  gap: 20px;
  flex-wrap: wrap;
}

/* ---------- Features Bar ---------- */
.features-bar {
  background: var(--color-deep-green);
  padding: 18px 0;
  color: #fff;
}

.features-bar__grid {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 16px;
  text-align: center;
}

.features-bar__item {
  display: flex;
  align-items: center;
  gap: 8px;
  font-weight: 500;
}

.features-bar__icon {
  font-size: 1.3rem;
  color: #F9D170;
}

/* ---------- About Snippet ---------- */
.about-snippet__row {
  display: flex;
  align-items: center;
  gap: 50px;
  flex-wrap: wrap;
}

.about-snippet__text {
  flex: 1 1 400px;
}

.about-snippet__text p {
  margin-bottom: 14px;
}

.about-snippet__image {
  flex: 1 1 400px;
  background: #e7cfb0;
  border-radius: var(--border-radius);
  height: 290px;
  overflow: hidden;
  box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);
}

.about-snippet__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.about-snippet__badges {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 16px;
}

.badge {
  background: #faead7;
  color: #8b5a2b;
  padding: 6px 14px;
  border-radius: 20px;
  font-weight: 600;
  font-size: 0.85rem;
  display: flex;
  align-items: center;
  gap: 5px;
}

/* ---------- Product Cards ---------- */
.product-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
  gap: 30px;
  margin-top: 20px;
}

.product-grid--full {
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
}

.product-card {
  background: #fff;
  border-radius: var(--border-radius);
  padding: 24px 16px 20px;
  text-align: center;
  box-shadow: var(--shadow-card);
  transition: transform 0.2s, box-shadow 0.2s;
  border: 1px solid #f0e4d0;
}

.product-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-card-hover);
}

.product-card__icon {
  font-size: 2.8rem;
  color: var(--color-terracotta);
  margin-bottom: 12px;
}

.product-card__title {
  font-size: 1.5rem;
  color: var(--color-dark-brown);
  margin-bottom: 6px;
}

.product-card__tags {
  margin: 10px 0 14px;
  display: flex;
  justify-content: center;
  gap: 6px;
  flex-wrap: wrap;
}

.tag {
  padding: 4px 12px;
  border-radius: 20px;
  font-weight: 600;
  font-size: 0.8rem;
}

.tag--vegan {
  background: #e8f5e9;
  color: #2d5a27;
}

.tag--meat {
  background: #fce4ec;
  color: #b33a2a;
}

.tag--mild,
.tag--medium {
  background: #fff3e0;
  color: #c67b4b;
}

.tag--hot {
  background: #fbe9e7;
  color: #b33a2a;
}

.tag--none {
  background: #f5f5f5;
  color: #666;
}

.product-card__description {
  font-size: 0.95rem;
  color: #5f4a34;
}

/* ---------- Steps (How It Works) ---------- */
.steps {
  display: flex;
  justify-content: center;
  gap: 45px;
  flex-wrap: wrap;
  text-align: center;
  margin-top: 20px;
}

.step {
  flex: 0 0 200px;
}

.step__number {
  background: var(--color-terracotta);
  color: #fff;
  width: 55px;
  height: 55px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.8rem;
  font-weight: 700;
  margin: 0 auto 16px;
  font-family: var(--font-heading);
}

.step__title {
  margin-bottom: 6px;
  color: var(--color-deep-green);
}

/* ---------- Testimonials ---------- */
.testimonials__grid {
  display: flex;
  gap: 30px;
  flex-wrap: wrap;
  justify-content: center;
}

.testimonial-card {
  background: #fff;
  border-radius: 20px;
  padding: 28px;
  max-width: 380px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.04);
  font-style: italic;
}

.testimonial-card__quote {
  color: var(--color-terracotta);
  font-size: 2rem;
  margin-bottom: 10px;
  display: block;
}

.testimonial-card__text {
  margin-bottom: 12px;
}

.testimonial-card__author {
  font-style: normal;
  font-weight: 700;
}

/* ---------- Page Header ---------- */
.page-header {
  background: var(--color-soft-white);
  padding: 50px 0;
  text-align: center;
  border-bottom: 1px solid var(--color-border-light);
}

.page-header__title {
  font-size: 2.8rem;
  color: var(--color-deep-green);
}

.page-header__subtitle {
  color: #5f4a34;
  font-size: 1.15rem;
  margin-top: 8px;
}

/* ---------- Promise Grid (About Page) ---------- */
.promise-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 28px;
  margin-top: 20px;
}

.promise-card {
  background: #fff;
  border-radius: 20px;
  padding: 28px 20px;
  text-align: center;
  box-shadow: var(--shadow-card);
  border: 1px solid #f0e4d0;
}

.promise-card__icon {
  font-size: 2.5rem;
  color: var(--color-terracotta);
  margin-bottom: 14px;
}

.promise-card h4 {
  color: var(--color-deep-green);
  margin-bottom: 8px;
}

/* ---------- Contact Layout ---------- */
.contact-layout {
  display: flex;
  gap: 40px;
  flex-wrap: wrap;
}

.contact-info {
  flex: 1 1 300px;
  background: var(--color-soft-white);
  padding: 32px;
  border-radius: var(--border-radius);
  border: 1px solid var(--color-border-light);
}

.contact-info__heading {
  font-size: 1.6rem;
  color: var(--color-deep-green);
  margin-bottom: 20px;
}

.contact-info__item {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 14px;
  font-size: 1.05rem;
}

.contact-info__item i {
  color: var(--color-terracotta);
  width: 20px;
  text-align: center;
}

.contact-info__note {
  margin-top: 24px;
  padding-top: 18px;
  border-top: 1px solid var(--color-border-light);
  color: var(--color-terracotta);
}

.contact-form {
  flex: 2 1 400px;
  background: #fff;
  padding: 32px;
  border-radius: var(--border-radius);
  box-shadow: var(--shadow-card);
}

.contact-form__heading {
  font-size: 1.6rem;
  color: var(--color-deep-green);
  margin-bottom: 20px;
}

.form-group {
  margin-bottom: 18px;
}

.form-group label {
  display: block;
  margin-bottom: 6px;
  font-weight: 600;
  color: var(--color-dark-brown);
}

.form-group input,
.form-group textarea {
  width: 100%;
  padding: 12px 16px;
  border-radius: 20px;
  border: 1px solid #ccc;
  font-family: var(--font-body);
  font-size: 1rem;
  transition: border-color var(--transition);
}

.form-group input:focus,
.form-group textarea:focus {
  outline: none;
  border-color: var(--color-terracotta);
}

.form-feedback {
  margin-top: 14px;
  padding: 12px;
  border-radius: 12px;
  font-weight: 600;
}

/* ---------- Recipe Cards ---------- */
.recipe-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 30px;
}

.recipe-card {
  background: #fff;
  border-radius: var(--border-radius);
  padding: 24px;
  text-align: center;
  box-shadow: var(--shadow-card);
  border: 1px solid #f0e4d0;
}

.recipe-card__image {
  height: 150px;
  border-radius: 16px;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.recipe-card h3 {
  color: var(--color-deep-green);
  margin-bottom: 8px;
}

/* ---------- CTA Section ---------- */
.cta {
  text-align: center;
}

/* ---------- Footer ---------- */
.footer {
  background: var(--color-footer-bg);
  color: var(--color-footer-text);
  padding: 50px 0 25px;
}

.footer__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 35px;
}

.footer__logo {
  color: #fff;
  font-family: var(--font-heading);
}

.footer__logo span {
  color: var(--color-terracotta);
}

.footer__tagline {
  font-size: 0.9rem;
  margin-top: 6px;
  opacity: 0.8;
}

.footer__heading {
  color: #fff;
  margin-bottom: 14px;
  font-size: 1.1rem;
}

.footer__links ul li {
  margin-bottom: 8px;
}

.footer__links a {
  color: var(--color-footer-link);
  transition: color var(--transition);
}

.footer__links a:hover {
  color: #fff;
}

.footer__contact p {
  margin-bottom: 8px;
}

.footer__contact i {
  margin-right: 8px;
  color: var(--color-terracotta);
}

.footer__bottom {
  text-align: center;
  margin-top: 35px;
  padding-top: 20px;
  border-top: 1px solid #5b4e3e;
  font-size: 0.9rem;
  opacity: 0.7;
}

/* ---------- Responsive Design ---------- */
@media (max-width: 768px) {
  .nav__menu {
    display: none;
    flex-direction: column;
    width: 100%;
    gap: 16px;
    padding: 20px 0;
    background: var(--color-soft-white);
  }
  
  .nav__menu.show {
    display: flex;
  }
  
  .nav__toggle {
    display: block;
  }
  
  .hero__title {
    font-size: 2.5rem;
  }
  
  .section__title {
    font-size: 2rem;
  }
  
  .about-snippet__row {
    flex-direction: column;
  }
}

@media (max-width: 480px) {
  .hero__title {
    font-size: 2rem;
  }
  
  .hero__description {
    font-size: 1.1rem;
  }
  
  .features-bar__grid {
    flex-direction: column;
    align-items: center;
  }
}
